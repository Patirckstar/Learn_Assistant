# ========================================
# Learn Assistant - 环境变量配置
# 复制此文件为 .env 并修改对应值
# ========================================

# ---- MySQL 数据库 ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=learn_assistant

# ---- Ollama 本地模型 ----
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b

# ---- 应用密钥（请修改为随机字符串） ----
SECRET_KEY=your-secret-key-here

# ---- 调试模式 ----
DEBUG=true
